# OpenRouter (required) — https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models — use stable models in production; free tiers may fail JSON/LaTeX
SCORING_MODEL=nvidia/nemotron-3-super-120b-a12b:free
CV_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LETTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
FALLBACK_MODEL=openai/gpt-oss-120b:free

# Paths and tooling
WORKSPACE_DIR=workspace
CV_VARIATIONS_DIR=cv_variations
LATEX_BIN=pdflatex
LOG_LEVEL=INFO

# Behaviour
TIMEZONE=Africa/Cairo
SCHEDULE_INTERVAL_HOURS=4
MAX_ROLES_PER_RUN=20
MIN_SCORE_TO_TAILOR=60

# Optional notifications (Windows toast when enabled)
NOTIFY_ENABLED=false
NOTIFY_MIN_TIER=strong
NOTIFY_WEBHOOK_URL=

# Supabase Postgres / web UI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=
WEB_HOST=127.0.0.1
WEB_PORT=8080
WEB_TOKEN=your-long-random-admin-token
ENVIRONMENT=local

# Public George profile
PUBLIC_CV_PATH=cv_variations/george_emil_aiml_engineer_cv.pdf
PUBLIC_EMAIL=
PUBLIC_LINKEDIN=
PUBLIC_GITHUB=
