# OpenRouter (required for real scoring/tailoring)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models
SCORING_MODEL=meta-llama/llama-3.3-70b-instruct:free
SCORING_MODEL_FAST=
CV_MODEL=deepseek/deepseek-r1-distill-llama-70b:free
LETTER_MODEL=deepseek/deepseek-r1-distill-llama-70b:free
FALLBACK_MODEL=openai/gpt-oss-120b:free

# Local Windows desktop paths
WORKSPACE_DIR=workspace
CV_VARIATIONS_DIR=cv_variations
DATABASE_URL=sqlite:///workspace/tracker/job_agent.db
LATEX_BIN=pdflatex
LOG_LEVEL=INFO

# Agent behaviour
TIMEZONE=Africa/Cairo
SCHEDULE_INTERVAL_HOURS=4
MAX_ROLES_PER_RUN=20
MIN_SCORE_TO_TAILOR=60
PERSIST_DRY_RUN_SCORES=true

# Scoring rate limits
SCORER_MAX_RETRIES=5
SCORER_BACKOFF_BASE_SECONDS=2.0
SCORER_DELAY_SECONDS=0

# Source controls (linkedin maps to linkedin_jobs internally)
ENABLED_SOURCES=wuzzuf,linkedin,bayt
SKIP_SLOW_SOURCES=true
ENABLE_INDEED=false
SCRAPER_TIMEOUT_SECONDS=25
MAX_SCORING_CANDIDATES=30
PREFILTER_MIN_SCORE=40
FAST_RUN_MAX_SCORING_CANDIDATES=20
DEEP_RUN_MAX_SCORING_CANDIDATES=40

# Optional notifications
NOTIFY_ENABLED=false
NOTIFY_MIN_TIER=strong
NOTIFY_WEBHOOK_URL=

# Run report retention (days, 0 = keep all)
RUN_REPORT_RETENTION_DAYS=30
