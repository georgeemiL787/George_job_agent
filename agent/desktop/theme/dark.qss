/* George Job Agent — dark modern dashboard */

QMainWindow, QDialog, QWidget {
    background-color: #0f1419;
    color: #e2e8f0;
    font-family: "Segoe UI", "Inter", sans-serif;
    font-size: 13px;
}

QTabWidget::pane {
    border: 1px solid #2d3a4f;
    border-radius: 8px;
    background: #0f1419;
    top: -1px;
}

QTabBar::tab {
    background: #1a2332;
    color: #94a3b8;
    padding: 10px 18px;
    margin-right: 4px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}

QTabBar::tab:selected {
    background: #243044;
    color: #2dd4bf;
    font-weight: 600;
}

QTabBar::tab:hover:!selected {
    background: #1e2a3d;
    color: #e2e8f0;
}

QGroupBox {
    border: 1px solid #2d3a4f;
    border-radius: 10px;
    margin-top: 14px;
    padding: 14px 12px 12px 12px;
    background: #1a2332;
    font-weight: 600;
    color: #94a3b8;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #2dd4bf;
}

QGroupBox#Card {
    background: #151d2b;
}

QPushButton {
    background: #243044;
    color: #e2e8f0;
    border: 1px solid #3d4f6a;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 500;
}

QPushButton:hover {
    background: #2d3f57;
    border-color: #2dd4bf;
}

QPushButton:pressed {
    background: #1a2332;
}

QPushButton#PrimaryButton {
    background: #0d9488;
    border-color: #2dd4bf;
    color: #0f1419;
    font-weight: 600;
}

QPushButton#PrimaryButton:hover {
    background: #2dd4bf;
}

QPushButton#DangerButton {
    background: #7f1d1d;
    border-color: #f87171;
    color: #fecaca;
}

QPushButton#DangerButton:hover {
    background: #b91c1c;
}

QPushButton:disabled {
    background: #1a2332;
    color: #64748b;
    border-color: #2d3a4f;
}

QLineEdit, QSpinBox, QComboBox, QDateEdit, QTextEdit {
    background: #0f1419;
    border: 1px solid #3d4f6a;
    border-radius: 6px;
    padding: 6px 8px;
    color: #e2e8f0;
    selection-background-color: #0d9488;
}

QLineEdit:focus, QTextEdit:focus, QSpinBox:focus, QComboBox:focus {
    border-color: #2dd4bf;
}

QTableWidget {
    background: #151d2b;
    alternate-background-color: #1a2332;
    gridline-color: #2d3a4f;
    border: 1px solid #2d3a4f;
    border-radius: 8px;
}

QTableWidget::item:selected {
    background: #0d9488;
    color: #0f1419;
}

QHeaderView::section {
    background: #1a2332;
    color: #94a3b8;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #2dd4bf;
    font-weight: 600;
}

QCheckBox {
    spacing: 8px;
    color: #cbd5e1;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1px solid #3d4f6a;
    background: #0f1419;
}

QCheckBox::indicator:checked {
    background: #2dd4bf;
    border-color: #2dd4bf;
}

QProgressBar {
    background: #0f1419;
    border: none;
    border-radius: 4px;
    min-height: 8px;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #0d9488, stop:1 #2dd4bf);
    border-radius: 4px;
}

QProgressBar#RunOverallBar {
    min-height: 10px;
}

QLabel#RunStatusLabel {
    font-size: 15px;
    font-weight: 600;
    color: #e2e8f0;
}

QLabel#RunEtaLabel {
    color: #94a3b8;
    font-size: 12px;
}

QFrame#RunLiveStrip {
    background: #151d2b;
    border: 1px solid #2d3a4f;
    border-radius: 12px;
    padding: 4px;
}

QWidget#RunWaitingPanel {
    background: #05050f;
    border: 1px solid #2d3a4f;
    border-radius: 12px;
}

QWidget#RunWaitingCanvas {
    background: #05050f;
    border-radius: 12px;
}

QFrame#MetricChip {
    background: #1a2332;
    border: 1px solid #2d3a4f;
    border-radius: 8px;
}

QLabel#MetricValue {
    font-size: 20px;
    font-weight: 700;
    color: #2dd4bf;
}

QLabel#MetricTitle {
    font-size: 11px;
    color: #94a3b8;
}

QLabel#PhasePill {
    min-width: 72px;
    padding: 6px 10px;
    border-radius: 16px;
    background: #1a2332;
    color: #64748b;
    border: 1px solid #2d3a4f;
    font-size: 12px;
    font-weight: 600;
}

QLabel#PhasePill[state="active"] {
    background: #0d3d38;
    color: #2dd4bf;
    border-color: #2dd4bf;
}

QLabel#PhasePill[state="done"] {
    background: #1e3a2f;
    color: #86efac;
    border-color: #22c55e;
}

QLabel#PhaseArrow {
    color: #475569;
    font-size: 16px;
}

QListWidget#ActivityList {
    background: #0f1419;
    border: 1px solid #2d3a4f;
    border-radius: 8px;
    font-family: "Cascadia Mono", "Consolas", monospace;
    font-size: 12px;
}

QScrollArea#TabScrollArea {
    background: transparent;
    border: none;
}

QScrollArea#TabScrollArea > QWidget > QWidget {
    background: transparent;
}

QScrollBar:vertical {
    background: #1a2332;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #3d4f6a;
    border-radius: 5px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background: #2dd4bf;
}
